{"fr":[{"partOfSpeech":"Adverb","language":"French","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/truly\" title=\"truly\">truly</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/really\" title=\"really\">really</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/genuinely\" title=\"genuinely\">genuinely</a>"},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt16\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/really\" title=\"really\">really</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/very\" title=\"very\">very</a>","parsedExamples":[{"example":"Elle est <b>vraiment</b> belle.","translation":"She is really beautiful."}],"examples":["Elle est <b>vraiment</b> belle."]}]},{"partOfSpeech":"Interjection","language":"French","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/really\" title=\"really\">really</a>? <a rel=\"mw:WikiLink\" href=\"/wiki/for_real\" title=\"for real\">for real</a>?"}]}]}