{"fr":[{"partOfSpeech":"Verb","language":"French","definitions":[{"definition":"to <a rel=\"mw:WikiLink\" href=\"/wiki/see\" title=\"see\">see</a> <span class=\"mention-gloss-paren\" about=\"#mwt64\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt64\">visually</span><span class=\"mention-gloss-paren\" about=\"#mwt64\">)</span>","parsedExamples":[{"example":"Je <b>vois</b> ma mère là-bas.","translation":"I <b>see</b> my mother over there."},{"example":"On ne <b>voit</b> pas souvent de la neige par ici.","translation":"One doesn't often <b>see</b> snow around here."}],"examples":["Je <b>vois</b> ma mère là-bas.","On ne <b>voit</b> pas souvent de la neige par ici."]},{"definition":"to <a rel=\"mw:WikiLink\" href=\"/wiki/see\" title=\"see\">see</a> <span class=\"mention-gloss-paren\" about=\"#mwt68\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt68\">to understand</span><span class=\"mention-gloss-paren\" about=\"#mwt68\">)</span>","parsedExamples":[{"example":"Tu <b>vois</b> que tu avais tort <span typeof=\"mw:Entity\">?</span>","translation":"Do you <b>see</b> that you were wrong?"}],"examples":["Tu <b>vois</b> que tu avais tort <span typeof=\"mw:Entity\">?</span>"]},{"definition":"to <a rel=\"mw:WikiLink\" href=\"/wiki/see\" title=\"see\">see</a> <span class=\"mention-gloss-paren\" about=\"#mwt71\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt71\">to visit, to go and see</span><span class=\"mention-gloss-paren\" about=\"#mwt71\">)</span>"}]},{"partOfSpeech":"Adverb","language":"French","definitions":[{"definition":"<span class=\"usage-label-sense\" about=\"#mwt78\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/please\" title=\"please\">please</a> (used to mark the imperative)","parsedExamples":[{"example":"Viens <b>voir</b> ici.","translation":"Come here <b>please</b>."},{"example":"<span class=\"Latn\" lang=\"fr\"><a rel=\"mw:WikiLink\" href=\"/wiki/voyons_voir#French\" title=\"voyons voir\">Voyons <b>voir</b></a></span>.","translation":"Let's see."},{"example":"Raconte-moi <b>voir</b> ça.","translation":"Tell me about it."}],"examples":["Viens <b>voir</b> ici.","<span class=\"Latn\" lang=\"fr\"><a rel=\"mw:WikiLink\" href=\"/wiki/voyons_voir#French\" title=\"voyons voir\">Voyons <b>voir</b></a></span>.","Raconte-moi <b>voir</b> ça."]}]}],"other":[{"partOfSpeech":"Verb","language":"Haitian Creole","definitions":[{"definition":"<span class=\"usage-label-sense\" about=\"#mwt88\" typeof=\"mw:Transclusion\"></span> to <a rel=\"mw:WikiLink\" href=\"/wiki/see\" title=\"see\">see</a>","parsedExamples":[{"example":"Mo <b>voir</b> ly ahier.","translation":"I <b>saw</b> him yesterday."}],"examples":["Mo <b>voir</b> ly ahier."]}]},{"partOfSpeech":"Noun","language":"Middle English","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt94\" typeof=\"mw:Transclusion\">alternative form of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"enm\"><a rel=\"mw:WikiLink\" href=\"/wiki/veir#Middle_English\" title=\"veir\">veir</a></i></span></span>"}]},{"partOfSpeech":"Adjective","language":"Old French","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/true\" title=\"true\">true</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/real\" title=\"real\">real</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/true\" title=\"true\">true</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/genuine\" title=\"genuine\">genuine</a>"}]},{"partOfSpeech":"Noun","language":"Old French","definitions":[{"definition":"the <a rel=\"mw:WikiLink\" href=\"/wiki/truth\" title=\"truth\">truth</a>"}]}]}