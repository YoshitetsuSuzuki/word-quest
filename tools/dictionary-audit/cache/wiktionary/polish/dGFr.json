b","language":"Old Polish","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a>, in this way"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a>, to such a degree"}]},{"partOfSpeech":"Conjunction","language":"Old Polish","definitions":[{"definition":"<span class=\"usage-label-sense\" about=\"#mwt306\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/as_well_as\" title=\"as well as\">as well as</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/both\" title=\"both\">both</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/and\" title=\"and\">and</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/therefore\" title=\"therefore\">therefore</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/thus\" title=\"thus\">thus</a>"},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt307\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/but\" title=\"but\">but</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/however\" title=\"however\">however</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/in_order_to\" title=\"in order to\">in order to</a>"},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt308\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/only_if\" title=\"only if\">only if</a>"}]},{"partOfSpeech":"Adverb","language":"Palula","definitions":[{"definition":"<span class=\"use-with-mention\" about=\"#mwt319\" typeof=\"mw:Transclusion\">co-lexicalized intensifier</span>"}]},{"partOfSpeech":"Adverb","language":"Slovincian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/thus\" title=\"thus\">thus</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/as_such\" title=\"as such\">as such</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a>"}]},{"partOfSpeech":"Noun","language":"Slovincian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/tact\" title=\"tact\">tact</a> <span class=\"mention-gloss-paren\" about=\"#mwt445\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt445\">keen perception or discernment</span><span class=\"mention-gloss-paren\" about=\"#mwt445\">)</span>"}]},{"partOfSpeech":"Noun","language":"Tyap","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/leg\" title=\"leg\">leg</a>"}]},{"partOfSpeech":"Verb","language":"Tyap","definitions":[{"definition":"to <a rel=\"mw:WikiLink\" href=\"/wiki/arrange\" title=\"arrange\">arrange</a>."},{"definition":"to <a rel=\"mw:WikiLink\" href=\"/wiki/tell\" title=\"tell\">tell</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/inform\" title=\"inform\">inform</a>"}]}],"cs":[{"partOfSpeech":"Adverb","language":"Czech","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a> (very)","parsedExamples":[{"example":"Je <b>tak</b> dobrý<span typeof=\"mw:Entity\">!</span>","translation":"He is <b>so</b> good!"},{"example":"Není to <b>tak</b> špatné.","translation":"It’s not <b>so</b> bad."}],"examples":["Je <b>tak</b> dobrý<span typeof=\"mw:Entity\">!</span>","Není to <b>tak</b> špatné."]},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a> <span class=\"mention-gloss-paren\" about=\"#mwt36\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt36\">therefore</span><span class=\"mention-gloss-paren\" about=\"#mwt36\">)</span>","parsedExamples":[{"example":"Chtěl knihu, <b>tak</b> si zašel do knihovny.","translation":"He wanted a book, <b>so</b> he went to the library."}],"examples":["Chtěl knihu, <b>tak</b> si zašel do knihovny."]},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a>, in that way","parsedExamples":[{"example":"Tak to chodí","translation":"That's the way it goes  <span style=\"font-style:normal\">(lit. \"so it goes\")</span>"}],"examples":["Tak to chodí"]}]},{"partOfSpeech":"Interjection","language":"Czech","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/so\" title=\"so\">so</a>","parsedExamples":[{"example":"<b>Tak</b> jděme<span typeof=\"mw:Entity\">!</span>","translation":"<b>So</b> let's go!"}],"examples":["<b>Tak</b> jděme<span typeof=\"mw:Entity\">!</span>"]}]}],"da":[{"partOfSpeech":"Noun","language":"Danish","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/thanks\" title=\"thanks\">thanks</a>"}]},{"partOfSpeech":"Interjection","language":"Danish","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/thank_you\" title=\"thank you\">thank you</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/thanks\" title=\"thanks\">thanks</a>"}]},{"partOfSpeech":"Noun","language":"Danish","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/jag\" title=\"jag\">jag</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/point\" title=\"point\">point</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/cog\" title=\"cog\">cog</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/tooth\" title=\"tooth\">tooth</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/tine\" title=\"tine\">tine</a>"}]},{"partOfSpeech":"Verb","language":"Danish","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt70\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/Appendix:Glossary#imperative_mood\" title=\"Appendix:Glossary\">imperative</a> of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"da\"><a rel=\"mw:WikiLink\" href=\"/wiki/takke#Danish\" title=\"takke\">takke</a></i></span></span>"}]}],"nl":[{"partOfSpeech":"Noun","language":"Dutch","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/branch\" title=\"branch\">branch</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/twig\" title=\"twig\">twig</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/bough\" title=\"bough\">bough</a>"},{"definition":"branch, <a rel=\"mw:WikiLink\" href=\"/wiki/offshoot\" title=\"offshoot\">offshoot</a>, 