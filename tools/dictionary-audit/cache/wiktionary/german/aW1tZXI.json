{"en":[{"partOfSpeech":"Noun","language":"English","definitions":[{"definition":"A bird in genus <span class=\"biota\" about=\"#mwt3\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/Gavia#Translingual\" title=\"Gavia\"><i>Gavia</i></a></span>."}]}],"other":[{"partOfSpeech":"Adverb","language":"Alemannic German","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/always\" title=\"always\">always</a>"},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt29\" typeof=\"mw:Transclusion\"></span> to a greater degree over time, <a rel=\"mw:WikiLink\" href=\"/wiki/more_and_more\" title=\"more and more\">more and more</a>","parsedExamples":[{"example":"Dr Unterschied zwüsche Arm und Riich wird <b>immer grösser</b>.","translation":"The difference between the poor and the rich is becoming <b>bigger and bigger</b>."}],"examples":["Dr Unterschied zwüsche Arm und Riich wird <b>immer grösser</b>."]}]},{"partOfSpeech":"Adverb","language":"Hunsrik","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/always\" title=\"always\">always</a>","parsedExamples":[{"example":"Du machst das <b>immer</b>.","translation":"You <b>always</b> do that."},{"example":"Es is <b>immer</b> so.","translation":"It's <b>always</b> like this."},{"example":"Sie nemmd <b>immer</b> eere grose Tasch mit.","translation":"She <b>always</b> takes her big purse with her."}],"examples":["Du machst das <b>immer</b>.","Es is <b>immer</b> so.","Sie nemmd <b>immer</b> eere grose Tasch mit."]}]},{"partOfSpeech":"Adverb","language":"Low German","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/always\" title=\"always\">always</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/forever\" title=\"forever\">forever</a>"}]},{"partOfSpeech":"Adverb","language":"Middle Dutch","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt138\" typeof=\"mw:Transclusion\">alternative form of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"dum\"><a rel=\"mw:WikiLink\" href=\"/wiki/emmer#Middle_Dutch\" title=\"emmer\">emmer</a></i></span></span>"}]},{"partOfSpeech":"Noun","language":"Yao (South America)","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/mother\" title=\"mother\">mother</a>"}]}],"nl":[{"partOfSpeech":"Adverb","language":"Dutch","definitions":[{"definition":"<span class=\"usage-label-sense\" about=\"#mwt48\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/always\" title=\"always\">always</a>","parsedExamples":[{"example":"Hij is <b>immer</b> beleefd tegen iedereen.","translation":"He is <b>always</b> polite to everyone."},{"example":"Het museum is <b>immer</b> geopend, zelfs op feestdagen.","translation":"The museum is open <b>always</b>, even on holidays."}],"examples":["Hij is <b>immer</b> beleefd tegen iedereen.","Het museum is <b>immer</b> geopend, zelfs op feestdagen."]}]}],"de":[{"partOfSpeech":"Adverb","language":"German","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/always\" title=\"always\">always</a>\n<ol><li>at all times without exception","parsedExamples":[{"example":"Irgendwo scheint <b>immer</b> die Sonne.","translation":"The sun is <b>always</b> shining somewhere."},{"example":"Er will <b>immer</b> nur fernsehen.","translation":"He just wants to watch telly <b>all the time</b>."},{"example":"Er erzählt <b>immer</b> dieselbe Geschichte.","translation":"He <b>always</b> tells that same story."}],"examples":["Irgendwo scheint <b>immer</b> die Sonne.","Er will <b>immer</b> nur fernsehen.","Er erzählt <b>immer</b> dieselbe Geschichte."]},{"definition":"at all times without exception","parsedExamples":[{"example":"Irgendwo scheint <b>immer</b> die Sonne.","translation":"The sun is <b>always</b> shining somewhere."}],"examples":["Irgendwo scheint <b>immer</b> die Sonne."]},{"definition":"very often; all the time; <a rel=\"mw:WikiLink\" href=\"/wiki/constantly\" title=\"constantly\">constantly</a>","parsedExamples":[{"example":"Er will <b>immer</b> nur fernsehen.","translation":"He just wants to watch telly <b>all the time</b>."}],"examples":["Er will <b>immer</b> nur fernsehen."]},{"definition":"every time; whenever some precondition is given","parsedExamples":[{"example":"Er erzählt <b>immer</b> dieselbe Geschichte.","translation":"He <b>always</b> tells that same story."}],"examples":["Er erzählt <b>immer</b> dieselbe Geschichte."]},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt82\" typeof=\"mw:Transclusion\"></span> to a greater degree over time, <a rel=\"mw:WikiLink\" href=\"/wiki/more_and_more\" title=\"more and more\">more and more</a>","parsedExamples":[{"example":"Es wird <b>immer</b> kälter.","translation":"It's getting colder and colder."}],"examples":["Es wird <b>immer</b> kälter."]},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt84\" typeof=\"mw:Transclusion\"></span> <span class=\"use-with-mention\" about=\"#mwt85\" typeof=\"mw:Transclusion\">used to emphasize another adverb of time, which itself is stressed</span>","parsedExamples":[{"example":"Er kommt <b>immer</b> nie pünktlich.","translation":"He’s never on time."},{"example":"Ich bin oft <b>immer</b> sehr vergesslich.","translation":"I’m often very forgetful."},{"example":"Manchmal hab ich <b>immer</b> das Gefühl, dass...","translation":"Sometimes I get the feeling that..."}],"examples":["Er kommt <b>immer</b> nie pünktlich.","Ich bin oft <b>immer</b> sehr vergesslich.","Manchmal hab ich <b>immer</b> das Gefühl, dass..."]}]}]}