{"bar":[{"partOfSpeech":"Adverb","language":"Bavarian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/again\" title=\"again\">again</a>"}]}],"de":[{"partOfSpeech":"Adverb","language":"German","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/again\" title=\"again\">again</a>; <span class=\"use-with-mention\" about=\"#mwt30\" typeof=\"mw:Transclusion\">indicates that the action taking place has happened before</span>","parsedExamples":[{"example":"Siehst du, jetzt hast du’s schon <b>wieder</b> gesagt<span typeof=\"mw:Entity\">!</span>","translation":"See, now you’ve said it <b>again!</b>"}],"examples":["Siehst du, jetzt hast du’s schon <b>wieder</b> gesagt<span typeof=\"mw:Entity\">!</span>"]},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/back\" title=\"back\">back</a>; <span class=\"use-with-mention\" about=\"#mwt33\" typeof=\"mw:Transclusion\">indicates that the action will return something to its original state or position</span>","parsedExamples":[{"example":"Schalte das Licht <b>wieder</b> aus.","translation":"Turn the light <b>back</b> off."}],"examples":["Schalte das Licht <b>wieder</b> aus."]}]}]}