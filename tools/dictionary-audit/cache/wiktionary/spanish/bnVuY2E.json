{"ast":[{"partOfSpeech":"Adverb","language":"Asturian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/never\" title=\"never\">never</a>","parsedExamples":[{"example":"<span class=\"mw-empty-elt\" about=\"#mwt7\" typeof=\"mw:Transclusion\"><link rel=\"mw:PageProp/Category\" href=\"./Category:ast:Time#NUNCA\"></span>"}],"examples":["<span class=\"mw-empty-elt\" about=\"#mwt7\" typeof=\"mw:Transclusion\"><link rel=\"mw:PageProp/Category\" href=\"./Category:ast:Time#NUNCA\"></span>"]}]}],"other":[{"partOfSpeech":"Adverb","language":"Chavacano","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/never\" title=\"never\">never</a>"}]},{"partOfSpeech":"Adverb","language":"Macanese","definitions":[{"definition":"<span class=\"use-with-mention\" about=\"#mwt31\" typeof=\"mw:Transclusion\">negation particle usually (but not always) used in the past tense</span>; <a rel=\"mw:WikiLink\" href=\"/wiki/did\" title=\"did\">did</a> <a rel=\"mw:WikiLink\" href=\"/wiki/not\" title=\"not\">not</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/had\" title=\"had\">had</a> <a rel=\"mw:WikiLink\" href=\"/wiki/not\" title=\"not\">not</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/would\" title=\"would\">would</a> <a rel=\"mw:WikiLink\" href=\"/wiki/not\" title=\"not\">not</a>","parsedExamples":[{"example":"Êle <b>nunca</b> vêm","translation":"He <b>did not</b> come"},{"example":"Êle já vai maz <b>nunca</b> volta","translation":"He left but <b>did not</b> return"},{"example":"Iou <b>nunca</b> capaz","translation":"I <b>wouldn't</b> dare"},{"example":"sâm <b>nunca</b><span typeof=\"mw:Entity\">?</span>","translation":"is<b>n't</b> it?"},{"example":"<b>nunca</b> nâ","translation":"<b>not</b> yet"}],"examples":["Êle <b>nunca</b> vêm","Êle já vai maz <b>nunca</b> volta","Iou <b>nunca</b> capaz","sâm <b>nunca</b><span typeof=\"mw:Entity\">?</span>","<b>nunca</b> nâ"]}]},{"partOfSpeech":"Particle","language":"Macanese","definitions":[{"definition":"<span class=\"use-with-mention\" about=\"#mwt45\" typeof=\"mw:Transclusion\">imperative article expressing negative future tense</span>; <a rel=\"mw:WikiLink\" href=\"/wiki/don't\" title=\"don't\">don't</a>","parsedExamples":[{"example":"<b>Nunca</b> assí pensam","translation":"<b>Don't</b> worry"}],"examples":["<b>Nunca</b> assí pensam"]}]},{"partOfSpeech":"Interjection","language":"Macanese","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/no\" title=\"no\">no</a>","parsedExamples":[{"example":"Sâm diabo<span typeof=\"mw:Entity\">?</span> <b>Nunca</b>, sâm tacho-sa<span typeof=\"mw:Entity\">!</span>","translation":"Is it diabo? <b>No</b>, it's a pan!"}],"examples":["Sâm diabo<span typeof=\"mw:Entity\">?</span> <b>Nunca</b>, sâm tacho-sa<span typeof=\"mw:Entity\">!</span>"]}]}],"gl":[{"partOfSpeech":"Adverb","language":"Galician","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/never\" title=\"never\">never</a>"}]}],"pt":[{"partOfSpeech":"Adverb","language":"Portuguese","definitions":[{"definition":""},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/never\" title=\"never\">never</a> <span class=\"mention-gloss-paren\">(</span><span class=\"mention-gloss\">at no time<span typeof=\"mw:Entity\">;</span> not ever</span><span class=\"mention-gloss-paren\">)</span>","parsedExamples":[{"example":"<b>Nunca</b> vi esse filme.","translation":"I have <b>never</b> seen this film."},{"example":"<b>Nunca</b> tenha certeza do sucesso.","translation":"<b>Never</b> be sure of success."}],"examples":["<b>Nunca</b> vi esse filme.","<b>Nunca</b> tenha certeza do sucesso."]}]},{"partOfSpeech":"Noun","language":"Portuguese","definitions":[{"definition":"<span class=\"usage-label-sense\" about=\"#mwt77\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/neverness\" title=\"neverness\">neverness</a> <span class=\"mention-gloss-paren\" about=\"#mwt78\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt78\">the quality of not ever being extant or present</span><span class=\"mention-gloss-paren\" about=\"#mwt78\">)</span>"}]}],"es":[{"partOfSpeech":"Adverb","language":"Spanish","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/never\" title=\"never\">never</a>","parsedExamples":[{"example":"<b>Nunca</b> he probado la langosta.","translation":"I've <b>never</b> tasted lobster."}],"examples":["<b>Nunca</b> he probado la langosta."]},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/ever\" title=\"ever\">ever</a>","parsedExamples":[{"example":"Estamos mejor que <b>nunca</b>.","translation":"We're better than <b>ever</b>."}],"examples":["Estamos mejor que <b>nunca</b>."]}]}]}