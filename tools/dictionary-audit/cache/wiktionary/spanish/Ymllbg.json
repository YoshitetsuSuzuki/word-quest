inition":"<span class=\"usage-label-sense\" about=\"#mwt52\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/a_lot_of\" title=\"a lot of\" class=\"mw-redirect\">a lot (of)</a>","parsedExamples":[{"example":"Macy Gray a traversé <b>bien</b> des épreuves.","translation":"Macy Gray got through <b>a lot</b> of ordeals."}],"examples":["Macy Gray a traversé <b>bien</b> des épreuves."]},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/very\" title=\"very\">very</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/really\" title=\"really\">really</a>","parsedExamples":[{"example":"C'est <b>bien</b> aimable à vous.","translation":"it's very considerate of you."},{"example":"C'est <b>bien</b> beau, mais...","translation":"It's all very well, but..."},{"example":"Je te trouve <b>bien</b> silencieux aujourd'hui.","translation":"You seem very quiet today."},{"example":"Il est <b>bien</b> moche, ce type. Ce type est vraiment moche.","translation":"That guy is <b>really</b> ugly."}],"examples":["C'est <b>bien</b> aimable à vous.","C'est <b>bien</b> beau, mais...","Je te trouve <b>bien</b> silencieux aujourd'hui.","Il est <b>bien</b> moche, ce type. Ce type est vraiment moche."]},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt59\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/much\" title=\"much\">much</a> <span class=\"mention-gloss-paren\" about=\"#mwt60\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt60\">more, less, better, etc.</span><span class=\"mention-gloss-paren\" about=\"#mwt60\">)</span>","parsedExamples":[{"example":"Jérémie est <b>bien</b> plus fort que moi.","translation":"Jérémie is much stronger than me."},{"example":"<b>bien</b> meilleur que <span class=\"q-hellip-sp\"> </span><span class=\"q-hellip-b\"><span typeof=\"mw:Entity\">[</span></span>…<span class=\"q-hellip-b\"><span typeof=\"mw:Entity\">]</span></span><span class=\"q-hellip-b\"></span>","translation":"much better than <s