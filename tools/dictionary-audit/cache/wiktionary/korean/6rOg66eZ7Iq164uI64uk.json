{"ko":[{"partOfSpeech":"Verb","language":"Korean","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/thank_you\" title=\"thank you\">thank you</a>; <span class=\"form-of-definition use-with-mention\" about=\"#mwt7\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink/Interwiki\" href=\"https://en.wikipedia.org/wiki/register%20(sociolinguistics)\" title=\"w:register (sociolinguistics)\" class=\"extiw\">formal</a> <a rel=\"mw:WikiLink/Interwiki\" href=\"https://en.wikipedia.org/wiki/T–V%20distinction\" title=\"w:T–V distinction\" class=\"extiw\">polite</a> <a rel=\"mw:WikiLink\" href=\"/wiki/Appendix:Glossary#indicative_mood\" title=\"Appendix:Glossary\">indicative</a> <a rel=\"mw:WikiLink\" href=\"/wiki/Appendix:Glossary#non-past_tense\" title=\"Appendix:Glossary\">non-past</a> of <span class=\"form-of-definition-link\"><i class=\"Kore mention\" lang=\"ko\"><a rel=\"mw:WikiLink\" href=\"/wiki/고맙다#Korean\" title=\"고맙다\">고맙다</a></i> <span class=\"mention-gloss-paren annotation-paren\">(</span><span lang=\"ko-Latn\" class=\"mention-tr tr Latn\">gomapda</span>, <span class=\"mention-gloss-double-quote\">“</span><span class=\"mention-gloss\">to be thankful</span><span class=\"mention-gloss-double-quote\">”</span><span class=\"mention-gloss-paren annotation-paren\">)</span></span></span>","parsedExamples":[{"example":"<a rel=\"mw:WikiLink\" href=\"/wiki/전화#Korean\" title=\"전화\">전화</a> 주셔서 <b>고맙습니다</b>.","transliteration":"Jeonhwa jusyeoseo <b>gomapseumnida</b>.","translation":"<b>Thanks</b> for calling."}],"examples":["<a rel=\"mw:WikiLink\" href=\"/wiki/전화#Korean\" title=\"전화\">전화</a> 주셔서 <b>고맙습니다</b>."]}]}]}