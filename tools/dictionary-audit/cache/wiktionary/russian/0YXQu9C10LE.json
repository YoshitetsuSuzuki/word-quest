{"be":[{"partOfSpeech":"Noun","language":"Belarusian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/bread\" title=\"bread\">bread</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/loaf\" title=\"loaf\">loaf</a>"}]}],"bg":[{"partOfSpeech":"Noun","language":"Bulgarian","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt20\" typeof=\"mw:Transclusion\">alternative form of <span class=\"form-of-definition-link\"><i class=\"Cyrl mention\" lang=\"bg\"><a rel=\"mw:WikiLink\" href=\"/wiki/хляб#Bulgarian\" title=\"хляб\">хляб</a></i> <span class=\"mention-gloss-paren annotation-paren\">(</span><span lang=\"bg-Latn\" class=\"mention-tr tr Latn\">hljab</span>, <span class=\"mention-gloss-double-quote\">“</span><span class=\"mention-gloss\">bread</span><span class=\"mention-gloss-double-quote\">”</span><span class=\"mention-gloss-paren annotation-paren\">)</span></span></span>"}]}],"ru":[{"partOfSpeech":"Noun","language":"Russian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/bread\" title=\"bread\">bread</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/loaf\" title=\"loaf\">loaf</a>"},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt47\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/black\" title=\"black\">black</a> <a rel=\"mw:WikiLink\" href=\"/wiki/bread\" title=\"bread\">bread</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/rye\" title=\"rye\">rye</a> <a rel=\"mw:WikiLink\" href=\"/wiki/bread\" title=\"bread\">bread</a>"}]},{"partOfSpeech":"Noun","language":"Russian","definitions":[{"definition":"<span class=\"usage-label-sense\" about=\"#mwt78\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/grain\" title=\"grain\">grain</a>","parsedExamples":[{"example":"<a rel=\"mw:WikiLink\" href=\"/wiki/ветер#Russian\" title=\"ветер\">ве́тер</a> <a rel=\"mw:WikiLink\" href=\"/wiki/колыхать#Russian\" title=\"колыхать\">колы́шет</a> <b>хлеба́</b>","transliteration":"véter kolýšet <b>xlebá</b>","translation":"the <b>grain</b> sways in the wind"}],"examples":["<a rel=\"mw:WikiLink\" href=\"/wiki/ветер#Russian\" title=\"ветер\">ве́тер</a> <a rel=\"mw:WikiLink\" href=\"/wiki/колыхать#Russian\" title=\"колыхать\">колы́шет</a> <b>хлеба́</b>"]},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt80\" typeof=\"mw:Transclusion\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/food\" title=\"food\">food</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/subsistence\" title=\"subsistence\">subsistence</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/living\" title=\"living\">living</a> (cf. <a rel=\"mw:WikiLink\" href=\"/wiki/breadwinner\" title=\"breadwinner\">breadwinner</a>)","parsedExamples":[{"example":"Раньше мы зарабатывали на <b>хлеб</b>, продавая яблоки.","transliteration":"Ranʹše my zarabatyvali na <b>xleb</b>, prodavaja jabloki.","translation":"We used to make a <b>living</b> by selling apples."},{"example":"<a rel=\"mw:WikiLink\" href=\"/wiki/фотография#Russian\" title=\"фотография\">фотогра́фия</a> — <a rel=\"mw:WikiLink\" href=\"/wiki/мой#Russian\" title=\"мой\">мой</a> <b>хлеб</b>","transliteration":"fotográfija — moj <b>xleb</b>","translation":"photography is my <b>living</b>"}],"examples":["Раньше мы зарабатывали на <b>хлеб</b>, продавая яблоки.","<a rel=\"mw:WikiLink\" href=\"/wiki/фотография#Russian\" title=\"фотография\">фотогра́фия</a> — <a rel=\"mw:WikiLink\" href=\"/wiki/мой#Russian\" title=\"мой\">мой</a> <b>хлеб</b>"]}]}],"sh":[{"partOfSpeech":"Noun","language":"Serbo-Croatian","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/bread\" title=\"bread\">bread</a>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/loaf\" title=\"loaf\">loaf</a> (of bread)"},{"definition":"circled <a rel=\"mw:WikiLink\" href=\"/wiki/shape\" title=\"shape\">shape</a> of bread"}]}]}