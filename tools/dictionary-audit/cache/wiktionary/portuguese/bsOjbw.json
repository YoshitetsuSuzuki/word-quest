{"roa-rup":[{"partOfSpeech":"Adjective","language":"Aromanian","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt3\" typeof=\"mw:Transclusion\">alternative form of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"rup\"><a rel=\"mw:WikiLink\" href=\"/wiki/nãu#Aromanian\" title=\"nãu\">nãu</a></i></span></span>"}]}],"gl":[{"partOfSpeech":"Adverb","language":"Galician","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt5\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/Appendix:Reintegrationism\" title=\"Appendix:Reintegrationism\">reintegrationist</a> spelling of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"gl\"><a rel=\"mw:WikiLink\" href=\"/wiki/non#Galician\" title=\"non\">non</a></i></span></span><link rel=\"mw:PageProp/Category\" href=\"./Category:Galician_reintegrationist_forms#NÃO\" about=\"#mwt5\">"}]},{"partOfSpeech":"Noun","language":"Galician","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt7\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/Appendix:Reintegrationism\" title=\"Appendix:Reintegrationism\">reintegrationist</a> spelling of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"gl\"><a rel=\"mw:WikiLink\" href=\"/wiki/non#Galician\" title=\"non\">non</a></i> <span class=\"mention-gloss-paren annotation-paren\">(</span><span class=\"mention-gloss-double-quote\">“</span><span class=\"mention-gloss\">no</span><span class=\"mention-gloss-double-quote\">”</span><span class=\"mention-gloss-paren annotation-paren\">)</span></span></span><link rel=\"mw:PageProp/Category\" href=\"./Category:Galician_reintegrationist_forms#NÃO\" about=\"#mwt7\">"}]}],"pt":[{"partOfSpeech":"Adverb","language":"Portuguese","definitions":[{"definition":""},{"definition":"<span class=\"usage-label-sense\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/not\" title=\"not\">not</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/don't\" title=\"don't\">don't</a>; <a rel=\"mw:WikiLink\" href=\"/wiki/haven't\" title=\"haven't\">haven't</a> <span class=\"mention-gloss-paren\">(</span><span class=\"mention-gloss\"><i>negates the meaning of the verb or adverb</i></span><span class=\"mention-gloss-paren\">)</span>","parsedExamples":[{"example":"Eu <b>não</b> li esse livro.","translation":"I <b>haven’t</b> read that book."},{"example":"Por favor, <b>não</b> faça isso.","translation":"Please, <b>don’t</b> do that."},{"example":"Eu <b>não</b> fiz nada.","translation":"I <b>didn’t</b> do anything.","literally":"I didn’t do nothing."},{"example":"Ninguém vai ser preso <b>não</b>.","translation":"Nobody is <b>really</b> going to be arrested."},{"example":"Não vi o João <b>não</b>.","translation":"I haven’t seen John, <b>no</b>."},{"example":"<b>Não</b> está mau o chá<span typeof=\"mw:Entity\">?</span>","translation":"<b>Isn’t</b> the tea bad?"}],"examples":["Eu <b>não</b> li esse livro.","Por favor, <b>não</b> faça isso.","Eu <b>não</b> fiz nada.","Ninguém vai ser preso <b>não</b>.","Não vi o João <b>não</b>.","<b>Não</b> está mau o chá<span typeof=\"mw:Entity\">?</span>"]},{"definition":"<span class=\"usage-label-sense\"></span> <span class=\"use-with-mention\">used in sentences containing a negative pronoun as the object<span typeof=\"mw:Entity\">;</span> see <a rel=\"mw:WikiLink\" href=\"/wiki/double_negative#English\" title=\"double negative\">double negative</a></span>","parsedExamples":[{"example":"Eu <b>não</b> fiz nada.","translation":"I <b>didn’t</b> do anything.","literally":"I didn’t do nothing."}],"examples":["Eu <b>não</b> fiz nada."]},{"definition":"<span class=\"usage-label-sense\"></span> <span class=\"use-with-mention\">used to emphasise or reinforce (in the case that there is a previous unstressed adverb <i class=\"Latn mention\" lang=\"pt\">não</i>, see above) sentences containing a negative pronoun as the subject or already containing <i class=\"Latn mention\" lang=\"pt\">não</i></span>","parsedExamples":[{"example":"Ninguém vai ser preso <b>não</b>.","translation":"Nobody is <b>really</b> going to be arrested."},{"example":"Não vi o João <b>não</b>.","translation":"I haven’t seen John, <b>no</b>."}],"examples":["Ninguém vai ser preso <b>não</b>.","Não vi o João <b>não</b>."]},{"definition":"<span class=\"usage-label-sense\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/isn't\" title=\"isn't\">isn't</a> <span class=\"mention-gloss-paren\">(</span><span class=\"mention-gloss\"><i>used to ask whether a person agrees with the proposition, rather than to ask for an unknown fact</i></span><span class=\"mention-gloss-paren\">)</span>","parsedExamples":[{"example":"<b>Não</b> está mau o chá<span typeof=\"mw:Entity\">?</span>","translation":"<b>Isn’t</b> the tea bad?"}],"examples":["<b>Não</b> está mau o chá<span typeof=\"mw:Entity\">?</span>"]},{"definition":""},{"definition":"<span class=\"usage-label-sense\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/non-\" title=\"non-\">non-</a> <span class=\"mention-gloss-paren\">(</span><span class=\"mention-gloss\"><i>forms antonyms of adjectives</i></span><span class=\"mention-gloss-paren\">)</span>","parsedExamples":[{"example":"O sistema é <b>não</b>-escalável.","translation":"The system is <b>non-</b>scalable."}],"examples":["O sistema é <b>não</b>-escalável."]},{"definition":""},{"definition":"<span class=\"usage-label-sense\"></span> <a rel=\"mw:WikiLink\" href=\"/wiki/isn't_it\" title=\"isn't it\">isn't it</a>? <a rel=\"mw:WikiLink\" href=\"/wiki/right\" title=\"right\">right</a>? <span class=\"mention-gloss-paren\">(</span><span class=\"mention-gloss\"><i>tag question</i></span><span class=\"mention-gloss-paren\">)</span>","parsedExamples":[{"example":"Ela está aqui, <b>não</b><span typeof=\"mw:Entity\">?</span>","translation":"She is here, <b>right</b>?"}],"examples":["Ela está aqui, <b>não</b><span typeof=\"mw:Entity\">?</span>"]}]},{"partOfSpeech":"Interjection","language":"Portuguese","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/no\" title=\"no\">no</a> <span class=\"mention-gloss-paren\" about=\"#mwt63\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt63\">used to show disagreement or negation</span><span class=\"mention-gloss-paren\" about=\"#mwt63\">)</span>"},{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/no\" title=\"no\">no</a> <span class=\"mention-gloss-paren\" about=\"#mwt66\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt66\">used to show agreement with a negative question</span><span class=\"mention-gloss-paren\" about=\"#mwt66\">)</span>"}]},{"partOfSpeech":"Noun","language":"Portuguese","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/no\" title=\"no\">no</a> <span class=\"mention-gloss-paren\" about=\"#mwt70\" typeof=\"mw:Transclusion\">(</span><span class=\"mention-gloss\" about=\"#mwt70\">a negative answer</span><span class=\"mention-gloss-paren\" about=\"#mwt70\">)</span>","parsedExamples":[{"example":"Hoje recebi duas respostas<span typeof=\"mw:Entity\">:</span> um sim e um <b>não</b>.","translation":"Today I received two answers: one yes and one <b>no</b>."}],"examples":["Hoje recebi duas respostas<span typeof=\"mw:Entity\">:</span> um sim e um <b>não</b>."]}]}],"vi":[{"partOfSpeech":"Noun","language":"Vietnamese","definitions":[{"definition":"<a rel=\"mw:WikiLink\" href=\"/wiki/brain\" title=\"brain\">brain</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/cerebrum\" title=\"cerebrum\">cerebrum</a>","parsedExamples":[{"example":"Bộ <b>não</b> người có nhiều điều chưa lí giải được.","translation":"There are still many unexplained things about the human <b>brain</b>."}],"examples":["Bộ <b>não</b> người có nhiều điều chưa lí giải được."]}]},{"partOfSpeech":"Romanization","language":"Vietnamese","definitions":[{"definition":"<span class=\"form-of-definition use-with-mention\" about=\"#mwt83\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/Sino-Vietnamese\" title=\"Sino-Vietnamese\">Sino-Vietnamese</a> reading of <span class=\"form-of-definition-link\"><i class=\"Hani mention\" lang=\"vi\"><a rel=\"mw:WikiLink\" href=\"/wiki/惱#Vietnamese\" title=\"惱\">惱</a></i></span></span><link rel=\"mw:PageProp/Category\" href=\"./Category:Sino-Vietnamese_readings\" about=\"#mwt83\">"}]}]}