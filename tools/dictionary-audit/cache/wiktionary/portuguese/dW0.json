{"en":[{"partOfSpeech":"Symbol","language":"Translingual","definitions":[{"definition":""},{"definition":"<span class=\"usage-label-sense\"></span> <span class=\"form-of-definition use-with-mention\">Alternative form of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"mul\"><a rel=\"mw:WikiLink\" href=\"/wiki/μm#Translingual:_Q175821\" title=\"μm\">μm</a></i></span></span>."}]},{"partOfSpeech":"Interjection","language":"English","definitions":[{"definition":"<span class=\"use-with-mention\" about=\"#mwt18\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/expression#English\" title=\"expression\">Expression</a> of <a rel=\"mw:WikiLink\" href=\"/wiki/hesitation#English\" title=\"hesitation\">hesitation</a>, <a rel=\"mw:WikiLink\" href=\"/wiki/uncertainty#English\" title=\"uncertainty\">uncertainty</a> or space <a rel=\"mw:WikiLink\" href=\"/wiki/filler#English\" title=\"filler\">filler</a> in <a rel=\"mw:WikiLink\" href=\"/wiki/conversation#English\" title=\"conversation\">conversation</a></span>.","parsedExamples":[{"example":"<b>Um</b>, I don’t know."},{"example":"Let’s see... <b>um</b>... how about this<span typeof=\"mw:Entity\">?</span>"}],"examples":["<b>Um</b>, I don’t know.","Let’s see... <b>um</b>... how about this<span typeof=\"mw:Entity\">?</span>"]},{"definition":"<span class=\"usage-label-sense\" about=\"#mwt25\" typeof=\"mw:Transclusion\"></span> <span class=\"form-of-definition use-with-mention\" about=\"#mwt26\" typeof=\"mw:Transclusion\"><a rel=\"mw:WikiLink\" href=\"/wiki/Appendix:Glossary#dated\" title=\"Appendix:Glossary\">Dated</a> spelling of <span class=\"form-of-definition-link\"><i class=\"Latn mention\" lang=\"en\"><a rel=\"mw:WikiLink\" href=\"/wiki/mmm#English\" title=\"mmm\">mmm</a></i></span></span><link rel=\"mw:PageProp/Category\" href=\"./Category:English_dated_forms#UM\" about=\"#mwt26\">."},{"definition":"<span class=\"use-with-mention\" about=\"#mwt28\" typeof=\"mw:Transclusion\">An expression t